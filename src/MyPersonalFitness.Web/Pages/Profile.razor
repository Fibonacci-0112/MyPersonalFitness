@page "/profile"
@inject MyPersonalFitness.Core.Interfaces.IUserProfileRepository UserRepo

<PageTitle>Profile – MyPersonalFitness</PageTitle>

<h1>👤 Profile</h1>
<p class="text-muted">Set up your personal information to enable accurate calorie and goal calculations.</p>

<div class="card" style="max-width:600px">
    <div class="card-body">
        <EditForm Model="_profile" OnValidSubmit="SaveProfile">
            <DataAnnotationsValidator />
            <div class="mb-3">
                <label class="form-label">Name</label>
                <InputText class="form-control" @bind-Value="_profile.Name" />
            </div>
            <div class="mb-3">
                <label class="form-label">Date of Birth</label>
                <InputDate class="form-control" @bind-Value="_profile.DateOfBirth" />
            </div>
            <div class="mb-3">
                <label class="form-label">Gender</label>
                <InputSelect class="form-select" @bind-Value="_profile.Gender">
                    @foreach (var g in Enum.GetValues<Gender>())
                    {
                        <option value="@g">@g</option>
                    }
                </InputSelect>
            </div>
            <div class="mb-3">
                <label class="form-label">Height (cm)</label>
                <InputNumber class="form-control" @bind-Value="_profile.HeightCm"
                             min="100" max="250" step="0.5" />
            </div>
            <div class="mb-3">
                <label class="form-label">Starting Weight (kg)</label>
                <InputNumber class="form-control" @bind-Value="_profile.StartingWeightKg"
                             min="30" max="400" step="0.1" />
                <div class="form-text">This is your weight at the beginning of your journey.</div>
            </div>
            <div class="mb-3">
                <label class="form-label">Activity Level</label>
                <InputSelect class="form-select" @bind-Value="_profile.ActivityLevel">
                    <option value="@ActivityLevel.Sedentary">Sedentary (little/no exercise)</option>
                    <option value="@ActivityLevel.LightlyActive">Lightly Active (1–3 days/week)</option>
                    <option value="@ActivityLevel.ModeratelyActive">Moderately Active (3–5 days/week)</option>
                    <option value="@ActivityLevel.VeryActive">Very Active (6–7 days/week)</option>
                    <option value="@ActivityLevel.ExtraActive">Extra Active (physical job + exercise)</option>
                </InputSelect>
            </div>
            <button type="submit" class="btn btn-primary">Save Profile</button>
            @if (_saved)
            {
                <span class="ms-2 text-success">✅ Saved!</span>
            }
        </EditForm>
    </div>
</div>

@if (_tdee.HasValue)
{
    <div class="alert alert-info mt-3" style="max-width:600px">
        <strong>Estimated TDEE:</strong> @_tdee.Value.ToString("F0") kcal/day
        <br /><small>Based on your current stats using the Mifflin–St Jeor formula.</small>
    </div>
}

@code {
    private UserProfile _profile = new()
    {
        DateOfBirth = DateTime.Today.AddYears(-30),
        Gender = Gender.PreferNotToSay
    };

    private bool _saved;
    private double? _tdee;

    protected override async Task OnInitializedAsync()
    {
        var existing = await UserRepo.GetCurrentUserAsync();
        if (existing != null)
            _profile = existing;
    }

    private async Task SaveProfile()
    {
        if (_profile.Id == 0)
        {
            _profile.StartDate = DateTime.UtcNow;
            await UserRepo.AddAsync(_profile);
        }
        else
        {
            _profile.UpdatedAt = DateTime.UtcNow;
            await UserRepo.UpdateAsync(_profile);
        }

        // Calculate TDEE for display
        int age = DateTime.UtcNow.Year - _profile.DateOfBirth.Year;
        double bmr = _profile.Gender == Gender.Female
            ? 10 * _profile.StartingWeightKg + 6.25 * _profile.HeightCm - 5 * age - 161
            : 10 * _profile.StartingWeightKg + 6.25 * _profile.HeightCm - 5 * age + 5;

        _tdee = _profile.ActivityLevel switch
        {
            ActivityLevel.Sedentary        => bmr * 1.2,
            ActivityLevel.LightlyActive    => bmr * 1.375,
            ActivityLevel.ModeratelyActive => bmr * 1.55,
            ActivityLevel.VeryActive       => bmr * 1.725,
            ActivityLevel.ExtraActive      => bmr * 1.9,
            _                              => bmr * 1.2
        };

        _saved = true;
        StateHasChanged();
        await Task.Delay(3000);
        _saved = false;
    }
}
